#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

BINS=(bonfyre-media-prep bonfyre-transcribe bonfyre-brief bonfyre-proof bonfyre-offer bonfyre-meter bonfyre-ledger bonfyre-pack bonfyre-emit)
require_bin "${BINS[@]}" || exit 0

CHANGED=$(git diff-tree --no-commit-id --name-only -r HEAD -- input/ 2>/dev/null || true)
[ -z "$CHANGED" ] && exit 0

log "Freelancer Evidence: processing $(echo "$CHANGED" | wc -l | tr -d ' ') file(s)…"

for f in $CHANGED; do
  [ -f "$f" ] || continue
  base=$(basename "$f" | sed 's/\.[^.]*$//')
  ext="${f##*.}"

  case "$ext" in
    wav|mp3|m4a|ogg|flac|webm)
      log "[$base] Full evidence pipeline: transcribe → proof → offer → meter → ledger → pack"
      bonfyre-media-prep "$f" --out "artifacts/${base}.prep.json"
      bonfyre-transcribe "artifacts/${base}.prep.json" --out "artifacts/${base}.transcript.json"
      bonfyre-brief "artifacts/${base}.transcript.json" --out "artifacts/${base}.brief.json"
      bonfyre-proof "artifacts/${base}.brief.json" --out "artifacts/${base}.proof.json"
      bonfyre-offer "artifacts/${base}.proof.json" --out "artifacts/${base}.offer.json"
      bonfyre-meter "artifacts/${base}.offer.json" --op evidence-capture
      bonfyre-ledger "artifacts/${base}.offer.json" --out "artifacts/${base}.value.json"
      bonfyre-pack "artifacts/${base}.proof.json" --out "artifacts/${base}.pack.zip"
      ;;
    pdf|docx|txt)
      log "[$base] Document evidence: brief → proof → offer"
      bonfyre-brief "$f" --out "artifacts/${base}.brief.json"
      bonfyre-proof "artifacts/${base}.brief.json" --out "artifacts/${base}.proof.json"
      bonfyre-offer "artifacts/${base}.proof.json" --out "artifacts/${base}.offer.json"
      ;;
    *) log "[$base] skipping: $ext" ;;
  esac
done

log "Generating evidence site…"
bonfyre-emit artifacts/ --out site/ --format html
log "Done. Evidence portfolio updated."

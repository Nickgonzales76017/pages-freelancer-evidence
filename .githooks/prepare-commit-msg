#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}

MSG_FILE="$1"
[ "${2:-}" = "merge" ] && exit 0

CALLS=$(git diff --cached --name-only -- 'input/*.wav' 'input/*.mp3' 'input/*.m4a' 2>/dev/null | wc -l | tr -d ' ')
DOCS=$(git diff --cached --name-only -- 'input/*.pdf' 'input/*.txt' 'input/*.docx' 2>/dev/null | wc -l | tr -d ' ')
[ "$CALLS" -eq 0 ] && [ "$DOCS" -eq 0 ] && exit 0

PARTS=()
[ "$CALLS" -gt 0 ] && PARTS+=("${CALLS} call(s)")
[ "$DOCS" -gt 0 ] && PARTS+=("${DOCS} doc(s)")
echo "[evidence] $(IFS=', '; echo "${PARTS[*]}")" > "$MSG_FILE"
